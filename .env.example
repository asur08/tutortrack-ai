# TutorTrack AI Environment Variables
# -----------------------------------
# To run locally with PostgreSQL, uncomment and set the DATABASE_URL below.
# If omitted, the app will automatically fall back to using a local SQLite file (tutortrack.db).
# 
# For Render deployment, set DATABASE_URL in your Render dashboard environment settings.

# DATABASE_URL=postgresql://user:password@localhost:5432/tutortrack

# Required for securely signing the session cookie for logged-in users.
# You can generate a random string using `python -c 'import secrets; print(secrets.token_hex())'`
FLASK_SECRET_KEY=your_secret_key_here

# Required for AI Student Insights
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
